---
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import MainSection from '@components/blocks/MainSection.astro'
import BlogCategory from '@components/blog/BlogCategory.astro'
import { timeago } from '../../support/time'
import { SITE } from '../../config'
import { getCategories, getPosts } from '../../support/content'

const postMap: Map<string, CollectionEntry<'posts'>[]> = (await getPosts()).sort(
    (a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).reduce((acc, obj) => {
    let posts = acc.get(obj.data.category)
    if (!posts) {
        posts = []
    }
    posts.push(obj)

    acc.set(obj.data.category, posts)

    return acc
}, new Map<string, CollectionEntry<'posts'>[]>())

const categories = await getCategories()
const description = ''
const URL = Astro.url.href
---

<BaseLayout
    title="All Categories"
    description={description}
    structuredData={{
        '@context': 'https://schema.org',
        '@type': 'WebPage',
        'inLanguage': 'en-US',
        '@id': URL,
        'url': URL,
        'name': `All Categories - ${SITE.title}`,
        'description': description,
        'isPartOf': {
            '@type': 'WebSite',
            'url': SITE.url,
            'name': SITE.title,
            'description': SITE.description,
        },
    }}
>
    <MainSection title="Categories" subTitle={description} />
    
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {categories.length > 0 ? categories.map((category) => (
                <BlogCategory
                    slug={category.slug}
                    title={category.data.title}
                    description={category.data.description}
                    count={(postMap.get(category.slug) || []).length}
                    publishDate={timeago(category.data.updatedDate || new Date())}
                />
            )) : (
                <div class="col-span-full rounded-xl border border-dashed border-neutral-300 p-10 text-center text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
                    No categories yet. They will appear here after you add categories and posts.
                </div>
            )}
        </div>
    </div>
</BaseLayout>
