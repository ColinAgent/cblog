---
import Redirect from '@components/Redirect.astro'
import { getCategories } from '../../support/content'
import { DEFAULT_LOCALE, getCategoryUrl, getContentSlug } from '../../i18n'

export async function getStaticPaths() {
    const categories = await getCategories(DEFAULT_LOCALE)
    return categories.map(category => {
        const slug = getContentSlug(category)
        return {
            params: { slug },
            props: { to: getCategoryUrl(DEFAULT_LOCALE, slug) },
        }
    })
}

const { to } = Astro.props
---

<Redirect to={to} />
