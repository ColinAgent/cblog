---
import Redirect from '@components/Redirect.astro'
import { getPosts } from '../../support/content'
import { DEFAULT_LOCALE, getContentSlug, getLocalePath } from '../../i18n'

export async function getStaticPaths() {
    const posts = await getPosts(false, DEFAULT_LOCALE)
    return posts.map(post => {
        const slug = getContentSlug(post)
        return {
            params: { slug },
            props: { to: getLocalePath(DEFAULT_LOCALE, `posts/${slug}`) },
        }
    })
}

const { to } = Astro.props
---

<Redirect to={to} />
