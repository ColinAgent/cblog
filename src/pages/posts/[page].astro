---
import Redirect from '@components/Redirect.astro'
import { SITE } from '../../config'
import { getPosts, sortPostsByDate } from '../../support/content'
import { DEFAULT_LOCALE, getPostsPageUrl } from '../../i18n'

export async function getStaticPaths() {
    const postsPerPage = SITE.pageSize || 9
    const totalPosts = sortPostsByDate(await getPosts(false, DEFAULT_LOCALE)).length
    const totalPages = Math.max(1, Math.ceil(totalPosts / postsPerPage))

    return Array.from({ length: totalPages }, (_, i) => {
        const page = i + 1
        return {
            params: { page: page.toString() },
            props: { to: getPostsPageUrl(DEFAULT_LOCALE, page) },
        }
    })
}

const { to } = Astro.props
---

<Redirect to={to} />
