---
import BaseLayout from '@layouts/BaseLayout.astro'
import MainSection from '@components/blocks/MainSection.astro'
import { SITE } from '../config'

const description = `About ${SITE.title}`
---

<BaseLayout title="About" description={description}>
    <MainSection title="About" subTitle="A brief introduction to the new blog." />

    <section class="mx-auto max-w-3xl px-4 py-10 text-neutral-700 dark:text-neutral-300 sm:px-6 lg:px-8">
        <p class="leading-8">
            The old notes have been removed. Add the blog introduction, author bio, and contact information here.
        </p>
    </section>
</BaseLayout>
