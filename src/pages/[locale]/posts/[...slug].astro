---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '@layouts/BaseLayout.astro'
import { timeago } from '../../../support/time'
import { SITE } from '../../../config'
import TableOfContents from '../../../components/blog/TableOfContents.astro'
import { getCategories, getPosts } from '../../../support/content'
import { getCategoryUrl, getContentLocale, getContentSlug, type Locale } from '../../../i18n'

export async function getStaticPaths() {
    const posts = await getPosts()
    return posts
        .map(post => {
            const locale = getContentLocale(post)
            return {
                params: { locale, slug: getContentSlug(post) },
                props: { post, locale },
            }
        })
}

const { post, locale } = Astro.props as { post: CollectionEntry<'posts'>; locale: Locale }
const { Content, headings, remarkPluginFrontmatter } = await post.render()

const categories = await getCategories(locale)
const category = categories.find(c => getContentSlug(c) === post.data.category) || categories[0]

const tags = post.data.tags ?? [category ? getContentSlug(category) : 'uncategorized']
const URL = Astro.url.href

const ogImage = typeof post.data.cardImage === 'object' ? post.data.cardImage : undefined
---

<BaseLayout
    title={post.data.title}
    description={post.data.description}
    ogImage={ogImage}
    lang={locale}
    structuredData={{
        '@context': 'https://schema.org',
        '@type': 'NewsArticle',
        '@id': URL,
        'url': URL,
        'description': post.data.description,
        'image': ogImage ? [ogImage] : [],
        'headline': post.data.title,
        'datePublished': post.data.pubDate,
        'dateModified': post.data.updatedDate ?? post.data.pubDate,
        'author': [{
            '@type': 'Person',
            'name': SITE.author,
            'url': SITE.url,
        }],
    }}
>
    <div class="relative lg:flex lg:gap-8 xl:gap-12">
        <!-- Main content -->
        <section class="mx-auto w-full max-w-4xl px-4 pb-12 pt-8 sm:px-6 lg:px-0 content-section">
            <div class="shadow-none sm:shadow-sm mt-4 sm:mt-0">
                {post.data.cardImage && typeof post.data.cardImage === 'object' && (
                    <div class="max-w-full">
                        <Image
                            class="w-full object-cover rounded-tl-sm rounded-tr-sm"
                            src={post.data.cardImage}
                            alt={post.data.title}
                            draggable="false"
                            format="avif"
                            loading="eager"
                            width={1200}
                            height={630}
                        />
                    </div>
                )}
                
                <div class="sm:dark:bg-neutral-900/30 sm:bg-neutral-100 px-0 sm:px-6 md:px-10 lg:px-14 py-6">
                    <!-- Post header: title and metadata -->
                    <header class="mb-10">
                        <h2 class="block text-balance text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-300 md:text-4xl lg:text-5xl">
                            {post.data.title}
                        </h2>
                        <ol class="flex items-center mt-2 text-sm">
                            {category && (
                                <li class="inline-flex items-center">
                                    <a
                                        class="flex items-center text-orange-400 hover:text-orange-500 transition-colors"
                                        href={getCategoryUrl(locale, getContentSlug(category))}
                                    >
                                        {category.data.title || getContentSlug(category)}
                                    </a>
                                    <svg
                                        class="flex-shrink-0 size-5 text-neutral-500 dark:text-neutral-600 mx-2"
                                        width="16"
                                        height="16"
                                        viewBox="0 0 16 16"
                                        fill="none"
                                        xmlns="http://www.w3.org/2000/svg"
                                        aria-hidden="true"
                                    >
                                        <path d="M6 13L10 3" stroke="currentColor" stroke-linecap="round"></path>
                                    </svg>
                                </li>
                            )}
                            <li class="inline-flex items-center text-neutral-500 dark:text-neutral-400">
                                {timeago(post.data.pubDate)}
                                <svg
                                    class="flex-shrink-0 size-5 text-neutral-500 dark:text-neutral-600 mx-2"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 16 16"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                    aria-hidden="true"
                                >
                                    <path d="M6 13L10 3" stroke="currentColor" stroke-linecap="round"></path>
                                </svg>
                            </li>
                            <li
                                class="inline-flex items-center text-neutral-500 dark:text-neutral-400"
                                aria-current="page"
                            >
                                {remarkPluginFrontmatter.minutesRead}
                            </li>
                        </ol>
                    </header>

                    <!-- Post content -->
                    <article class="prose prose-blog sm:prose-lg dark:prose-invert max-w-none">
                        <Content />
                    </article>

                    <!-- Post footer: tags -->
                    <footer class="mt-10 md:mt-14">
                        <div class="flex flex-wrap gap-2">
                            {tags.map((tag: string) => (
                                <span class="inline-flex items-center rounded-lg bg-neutral-400/30 px-3 py-1.5 text-xs font-medium text-neutral-700 dark:bg-neutral-700/60 dark:text-neutral-300">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </footer>
                </div>
            </div>
        </section>

        <!-- Right fixed table of contents -->
        <aside class="hidden lg:block sticky top-28 z-10 h-[calc(100vh-120px)] overflow-y-auto lg:w-[260px] xl:w-[280px]" aria-label="Table of contents navigation">
            <TableOfContents 
                headings={headings.filter(h => h.depth >= 1 && h.depth <= 4)} 
                title={post.data.title}
            />
        </aside>
    </div>
</BaseLayout>

<style>
  /* Add smooth transitions to TOC items on hover */
  .toc-container a {
    display: block;
    padding: 0.25rem 0;
    transition: all 0.2s ease;
  }
</style>
