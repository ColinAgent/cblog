---
import Redirect from '@components/Redirect.astro'
import { LOCALES, getPostsPageUrl, type Locale } from '../../../i18n'

export const prerender = true

export function getStaticPaths() {
    return LOCALES.map(locale => ({
        params: { locale },
        props: { locale },
    }))
}

const { locale } = Astro.props as { locale: Locale }
---

<Redirect to={getPostsPageUrl(locale, 1)} />
