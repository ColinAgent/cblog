---
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import MainSection from '@components/blocks/MainSection.astro'
import BlogCategory from '@components/blog/BlogCategory.astro'
import { timeago } from '../../../support/time'
import { SITE } from '../../../config'
import { getCategories, getPosts, sortPostsByDate } from '../../../support/content'
import { LOCALES, UI, getCategoryUrl, getContentSlug, type Locale } from '../../../i18n'

export async function getStaticPaths() {
    return LOCALES.map(locale => ({
        params: { locale },
        props: { locale },
    }))
}

const { locale } = Astro.props as { locale: Locale }
const t = UI[locale]
const postMap: Map<string, CollectionEntry<'posts'>[]> = sortPostsByDate(await getPosts(false, locale)).reduce((acc, obj) => {
    let posts = acc.get(obj.data.category)
    if (!posts) {
        posts = []
    }
    posts.push(obj)

    acc.set(obj.data.category, posts)

    return acc
}, new Map<string, CollectionEntry<'posts'>[]>())

const categories = await getCategories(locale)
const description = t.pages.categoriesDescription
const URL = Astro.url.href
---

<BaseLayout
    title={t.pages.categoriesTitle}
    description={description}
    lang={locale}
    structuredData={{
        '@context': 'https://schema.org',
        '@type': 'WebPage',
        'inLanguage': locale === 'zh' ? 'zh-CN' : 'en-US',
        '@id': URL,
        'url': URL,
        'name': `${t.pages.categoriesTitle} - ${SITE.title}`,
        'description': description,
        'isPartOf': {
            '@type': 'WebSite',
            'url': SITE.url,
            'name': SITE.title,
            'description': SITE.description,
        },
    }}
>
    <MainSection title={t.pages.categoriesTitle} subTitle={description} />
    
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {categories.length > 0 ? categories.map((category) => {
                const slug = getContentSlug(category)
                return (
                    <BlogCategory
                        slug={slug}
                        url={getCategoryUrl(locale, slug)}
                        title={category.data.title}
                        description={category.data.description}
                        count={(postMap.get(slug) || []).length}
                        publishDate={timeago(category.data.updatedDate || new Date())}
                        countLabel={t.common.posts}
                        updateLabel={t.common.updated}
                    />
                )
            }) : (
                <div class="col-span-full rounded-xl border border-dashed border-neutral-300 p-10 text-center text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
                    {t.common.noCategories}
                </div>
            )}
        </div>
    </div>
</BaseLayout>
