---
import BaseLayout from '@layouts/BaseLayout.astro'
import MainSection from '@components/blocks/MainSection.astro'
import { SITE } from '../../config'
import { LOCALES, UI, type Locale } from '../../i18n'

export function getStaticPaths() {
    return LOCALES.map(locale => ({
        params: { locale },
        props: { locale },
    }))
}

const { locale } = Astro.props as { locale: Locale }
const t = UI[locale]
const description = `${t.pages.aboutTitle} ${SITE.title}`
---

<BaseLayout title={t.pages.aboutTitle} description={description} lang={locale}>
    <MainSection title={t.pages.aboutTitle} subTitle={t.pages.aboutSubtitle} />

    <section class="mx-auto max-w-3xl px-4 py-10 text-neutral-700 dark:text-neutral-300 sm:px-6 lg:px-8">
        <p class="leading-8">
            {t.pages.aboutBody}
        </p>
    </section>
</BaseLayout>
