---
const { title, url } = Astro.props

interface Props {
    title?: string
    url?: string
}

const baseClasses = 'group inline-flex items-center justify-center gap-x-3 rounded-full px-4 py-3 text-sm font-medium text-neutral-700 ring-zinc-500 transition duration-300 focus-visible:ring outline-none'
const borderClasses = 'border border-transparent'
const bgColorClasses = 'bg-yellow-400 dark:focus:outline-none'
const hoverClasses = 'hover:shadow-2xl hover:shadow-yellow-500'
const fontSizeClasses = '2xl:text-base'
const ringClasses = 'dark:ring-zinc-200'
---

<a
    class={`${baseClasses} ${borderClasses} ${bgColorClasses} ${hoverClasses} ${fontSizeClasses} ${ringClasses}`}
    href={url}
    target="_blank"
    rel="noopener noreferrer"
>
    <svg
        class="h-4 w-4 flex-shrink-0"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="currentColor"
        stroke="none"
    >
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
    </svg>
    {title}
</a>