---
interface Props {
    to: string
}

const { to } = Astro.props
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta http-equiv="refresh" content={`0;url=${to}`} />
        <link rel="canonical" href={to} />
        <script define:vars={{ to }}>
            window.location.replace(to)
        </script>
    </head>
    <body>
        <p>Redirecting to <a href={to}>{to}</a>…</p>
    </body>
</html>
