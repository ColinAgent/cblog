---
import { getFooterLinks, getLocaleFromPath, type Locale } from '../i18n'

interface Props {
    locale?: Locale
}

const locale = Astro.props.locale ?? getLocaleFromPath(Astro.url.pathname)
const footerLinks = getFooterLinks(locale)
---

<footer class="w-full bg-neutral-300 dark:bg-neutral-900">
    <div class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-16 2xl:max-w-screen-2xl">
        <div class="flex flex-col items-center gap-8">
            <nav aria-label="Footer navigation" class="flex w-full flex-col items-center gap-4">
                {
                    footerLinks.map(section => (
                        <div class="flex w-full flex-col items-center justify-center gap-3 sm:flex-row">
                            <h3 class="w-24 shrink-0 text-center text-base font-bold text-neutral-800 dark:text-neutral-200 sm:text-right">
                                {section.section}
                            </h3>
                            <ul class="flex flex-wrap justify-center gap-3">
                                {section.links.map(link => (
                                    <li>
                                        <a
                                            href={link.url}
                                            class="inline-flex min-w-28 items-center justify-center rounded-full border border-neutral-400/60 px-4 py-2 text-sm font-medium text-neutral-700 outline-none ring-zinc-500 transition duration-300 hover:border-neutral-500 hover:bg-neutral-200 hover:text-neutral-900 focus-visible:ring dark:border-neutral-700 dark:text-neutral-300 dark:ring-zinc-200 dark:hover:border-neutral-500 dark:hover:bg-neutral-800 dark:hover:text-neutral-100 dark:focus:outline-none"
                                        >
                                            {link.name}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </nav>
        </div>
    </div>
</footer>
