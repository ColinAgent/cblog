---
import BaseHead from '@components/BaseHead.astro'
import Footer from '@components/Footer.astro'
import Header from '@components/Header.astro'
import GoogleAnalytics from '@components/support/GoogleAnalytics.astro'
import { SITE } from '../config'

interface Props {
    title?: string
    description?: string
    seo?: {
        title?: string
        description?: string
        ogImage?: any
    }
    ogImage?: any
    lang?: string
    structuredData?: object
}

const { title, description, seo, ogImage, lang = 'en', structuredData } = Astro.props
const pageTitle = title ?? seo?.title ?? ''
const pageDescription = description ?? seo?.description ?? SITE.description
const pageOgImage = ogImage ?? seo?.ogImage
const normalizeTitle = !pageTitle ? SITE.title : `${pageTitle} - ${SITE.title}`
---

<html lang={lang} class="scrollbar-hide lenis lenis-smooth scroll-pt-16">
    <head>
        <title>{normalizeTitle}</title>
        <BaseHead
            title={normalizeTitle}
            description={pageDescription}
            ogImage={pageOgImage}
            ogTitle={pageTitle === '' ? SITE.title : pageTitle}
            ogDescription={pageDescription}
            structuredData={structuredData}
        />
        <script is:inline>
            // if (localStorage.getItem("hs_theme") === "dark"
            //     || (!("hs_theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
            //     document.documentElement.classList.add("dark");
            // } else {
            //     document.documentElement.classList.remove("dark");
            // }
              const theme = (() => {
                if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                    return localStorage.getItem('theme');
                }
                // Do not check system preferences; default to light mode
                return 'light';
            })();
            document.documentElement.classList.add(theme);
        </script>
        <script is:inline src="/vendor/lenis/lenis1.0.42.min.js"></script>
        <script is:inline>
            const lenis = new Lenis();
            function raf(time) {
                lenis.raf(time)
                requestAnimationFrame(raf)
            }
            requestAnimationFrame(raf)
        </script>
        <GoogleAnalytics />
    </head>
    <body class="bg-neutral-200 selection:bg-yellow-400 selection:text-neutral-700 dark:bg-neutral-800">
        <div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8">
            <Header />
            <main>
                <slot />
            </main>
        </div>
        <Footer />
        <style>
            .scrollbar-hide::-webkit-scrollbar {
                display: none;
            }
            .scrollbar-hide {
                -ms-overflow-style: none;
                scrollbar-width: none;
            }
            html.lenis,
            html.lenis body {
                height: auto;
            }
            .lenis.lenis-smooth {
                scroll-behavior: auto !important;
            }
            .lenis.lenis-smooth [data-lenis-prevent] {
                overscroll-behavior: contain;
            }
            .lenis.lenis-stopped {
                overflow: hidden;
            }
            .lenis.lenis-scrolling iframe {
                pointer-events: none;
            }
            /* Center images */
            :global(img) {
                @apply mx-auto;
            }

            /* Beautify H1 headings in Markdown posts */
            :global(article.prose h1) {
                display: table;
                padding: 0 1em;
                padding-top: 50px;
                padding-right: 1em;
                padding-bottom: 0px;
                padding-left: 1em;
                border-bottom-width: 2px;
                border-bottom-style: solid;
                margin: 2em auto 1em;
                margin-top: 2em;
                margin-right: auto;
                margin-bottom: 1em;
                margin-left: auto;
                color: rgb(0, 155, 121);
                font-size: 1.3em;
                font-weight: bold;
                text-align: center;
                background: none;
                -webkit-background-clip: initial;
                background-clip: initial;
                width: auto;
     
            }
        
            /* H2 headings in Markdown posts */
            :global(article.prose h2) {
                padding-left: 8px;
                border-left: 3px solid rgb(0, 155, 121);
                margin: 2em 8px 0.75em 0;
                margin-top: 2em;
                margin-right: 8px;
                margin-bottom: 0.75em;
                margin-left: 0px;
                color: rgb(0, 155, 121);
                font-size: 1.2em;
                font-weight: bold;
                line-height: 1.5;
                background: none;
                -webkit-background-clip: initial;
                background-clip: initial;
            }

            :global(article.prose h3) {
                margin: 2em 8px 0.75em 0;
                margin-top: 2em;
                margin-right: 8px;
                margin-bottom: 0.75em;
                margin-left: 0px;
                color: rgb(0, 155, 121);
                font-size: 1.1em;
                font-weight: bold;
                line-height: 1.5;
                background: none;
                -webkit-background-clip: initial;
                background-clip: initial;
            }

                /* Post page title (h2) styles */
                :global(.sm\:dark\:bg-neutral-900\/30 h2.block.text-balance) {
                color: rgb(0, 155, 121);
                border-bottom: 2px solid rgb(0, 155, 121);
                padding-bottom: 0.2em;
                font-size: 1.8em;
                background: none;
                -webkit-background-clip: initial;
                background-clip: initial;
            }
            
            
            /* Use an orange gradient for H1 headings on regular pages */
            /*:global(h1:not(article.prose h1)) {
                @apply text-3xl md:text-4xl lg:text-5xl font-bold my-6 text-neutral-900 dark:text-neutral-100;
                @apply text-center w-full block;
                background: linear-gradient(to right, rgba(234, 88, 12, 0.8), rgba(251, 113, 59, 0.4));
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
            }*/

            /* Force links inside prose to wrap when needed */
            :global(.prose a),
            :global(.prose-blog a) {
                overflow-wrap: break-word;
                word-wrap: break-word; /* Support older browsers */
                word-break: break-word; /* Ensure words can break */
            }

            /* Optional: force code blocks inside prose to scroll horizontally */
            :global(.prose pre),
            :global(.prose-blog pre) {
                overflow-x: auto;
                white-space: pre;
            }
        </style>
    </body>
</html>
